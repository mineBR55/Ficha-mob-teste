                    <upperGridCampo field="experiencia.valor" titulo="XP"/>
                    <upperGridCampo field="raca" minWidth="100" titulo="Origem / Grupo"/>
                    <upperGridCampo field="nomeDoJogador" titulo="Fonte / Livro"/>
