                </flowPart>

                <flowPart minWidth="240" maxWidth="700" height="64" frameStyle="frames/posCaptionEdit2/frame.xml">
                    <edit align="left" class="pericia" field="bonusHabilidades" width="70"/>
                    <label align="client" text="Bônus Global de Perícias" margins="{left=10}" class="tituloCampo" horzTextAlign="center"/>
                </flowPart>

                <flowPart minWidth="240" maxWidth="700" height="64" frameStyle="frames/posCaptionEdit2/frame.xml">
